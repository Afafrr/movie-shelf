<h1>Users#new</h1>

<div>
    <%= form_with url: :login, method: :post do |form| %>
        <div>
            <%= form.label :email, style: "display: block" %>
            <%= form.email_field :email %>
        </div>
        <div>
            <%= form.label :password, style:'display: block' %>
            <%= form.password_field :password %>
        </div>
        <%= form.submit "Log in" %>
    <% end %>
</div>
